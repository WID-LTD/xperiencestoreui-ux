{
  "buildCommand": "npm run build:css",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/.well-known/apple-developer-merchantid-domain-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    },
    {
      "source": "/google039751d2f5f591a7.html",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/(.*)",
      "destination": "/.well-known/$1"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://api.xperiencestore.store/sitemap.xml"
    },
    {
      "source": "/google039751d2f5f591a7.html",
      "destination": "/google039751d2f5f591a7.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
